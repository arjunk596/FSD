<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Profile</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 400px;
            margin: 50px auto;
            padding: 20px;
        }

        .card {
            background: #f4f4f4;
            padding: 20px;
            border-radius: 8px;
        }
    </style>
</head>

<body>
    <div class="card">
        <h1>Student Profile</h1>
        <p><strong>Name:</strong>
            <%= name %>
        </p>
        <p><strong>Branch:</strong>
            <%= branch %>
        </p>
        <p><strong>Year:</strong>
            <%= year %>
        </p>
    </div>
</body>

</html>